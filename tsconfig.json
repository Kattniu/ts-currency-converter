{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./src/scripts",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/*.ts",
    "server/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}